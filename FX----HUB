-- FX-Hub 2026 - Key System Corrigida (Botão Entrar visível)
-- Key: yurizin

local player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")

local validKey = "yurizin"

local keyGui = Instance.new("ScreenGui")
keyGui.Name = "FXKeySystem"
keyGui.Parent = game.CoreGui
keyGui.ResetOnSpawn = false

local frame = Instance.new("Frame", keyGui)
frame.Size = UDim2.new(0, 400, 0, 280)
frame.Position = UDim2.new(0.5, -200, 0.5, -140)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true

Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 16)

local stroke = Instance.new("UIStroke", frame)
stroke.Color = Color3.fromRGB(220, 20, 20)
stroke.Thickness = 3

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1, 0, 0, 60)
title.BackgroundTransparency = 1
title.Text = "FX-Hub 🎩"
title.TextColor3 = Color3.fromRGB(255, 215, 0)
title.Font = Enum.Font.GothamBlack
title.TextSize = 34

local subtitle = Instance.new("TextLabel", frame)
subtitle.Size = UDim2.new(1, 0, 0, 30)
subtitle.Position = UDim2.new(0, 0, 0, 65)
subtitle.BackgroundTransparency = 1
subtitle.Text = "Insira a key para continuar"
subtitle.TextColor3 = Color3.fromRGB(200, 200, 200)
subtitle.Font = Enum.Font.GothamSemibold
subtitle.TextSize = 18

local keyBox = Instance.new("TextBox", frame)
keyBox.Size = UDim2.new(0.8, 0, 0, 50)
keyBox.Position = UDim2.new(0.1, 0, 0, 110)
keyBox.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
keyBox.TextColor3 = Color3.white
keyBox.PlaceholderText = "Cole a key aqui..."
keyBox.Font = Enum.Font.Gotham
keyBox.TextSize = 20
keyBox.ClearTextOnFocus = false
Instance.new("UICorner", keyBox).CornerRadius = UDim.new(0, 10)

local enterBtn = Instance.new("TextButton", frame)
enterBtn.Size = UDim2.new(0.8, 0, 0, 55)
enterBtn.Position = UDim2.new(0.1, 0, 0, 175)
enterBtn.BackgroundColor3 = Color3.fromRGB(220, 20, 20)
enterBtn.Text = "ENTRAR"
enterBtn.TextColor3 = Color3.white
enterBtn.Font = Enum.Font.GothamBold
enterBtn.TextSize = 24
Instance.new("UICorner", enterBtn).CornerRadius = UDim.new(0, 12)

local errorLabel = Instance.new("TextLabel", frame)
errorLabel.Size = UDim2.new(0.8, 0, 0, 30)
errorLabel.Position = UDim2.new(0.1, 0, 0, 240)
errorLabel.BackgroundTransparency = 1
errorLabel.Text = ""
errorLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
errorLabel.Font = Enum.Font.Gotham
errorLabel.TextSize = 16
errorLabel.Visible = false

-- Hover no botão
enterBtn.MouseEnter:Connect(function()
    TweenService:Create(enterBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 50, 50)}):Play()
end)
enterBtn.MouseLeave:Connect(function()
    TweenService:Create(enterBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(220, 20, 20)}):Play()
end)

local function verificarKey()
    local texto = keyBox.Text:lower():gsub("%s+", "")
    if texto == validKey then
        errorLabel.Text = "Key correta! Carregando..."
        errorLabel.TextColor3 = Color3.fromRGB(0, 255, 120)
        errorLabel.Visible = true
        wait(1)
        keyGui:Destroy()
        print("✅ FX-Hub carregado com sucesso!")
        -- Aqui vai o painel principal (adicione o createMainPanel() se quiser)
    else
        errorLabel.Text = "Key errada! Tente novamente."
        errorLabel.Visible = true
    end
end

enterBtn.MouseButton1Click:Connect(verificarKey)
keyBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then verificarKey() end
end)

print("Key System carregada! Use yurizin")
