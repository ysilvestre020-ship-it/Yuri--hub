local function showLoadingScreen()
    local loadingGui = Instance.new("ScreenGui")
    loadingGui.Name = "FXLoading"
    loadingGui.Parent = game.CoreGui

    local frame = Instance.new("Frame", loadingGui)
    frame.Size = UDim2.new(0, 400, 0, 220)
    frame.Position = UDim2.new(0.5, -200, 0.5, -110)
    frame.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 16)

    local titleLoad = Instance.new("TextLabel", frame)
    titleLoad.Size = UDim2.new(1, 0, 0, 60)
    titleLoad.BackgroundTransparency = 1
    titleLoad.Text = "FX-Hub 🎩"
    titleLoad.TextColor3 = Color3.fromRGB(255, 215, 0)
    titleLoad.Font = Enum.Font.GothamBlack
    titleLoad.TextSize = 34

    local loadingBarBg = Instance.new("Frame", frame)
    loadingBarBg.Size = UDim2.new(0.8, 0, 0, 25)
    loadingBarBg.Position = UDim2.new(0.1, 0, 0, 140)
    loadingBarBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", loadingBarBg).CornerRadius = UDim.new(0, 12)

    local loadingBar = Instance.new("Frame", loadingBarBg)
    loadingBar.Size = UDim2.new(0, 0, 1, 0)
    loadingBar.BackgroundColor3 = Color3.fromRGB(220, 20, 20)
    Instance.new("UICorner", loadingBar).CornerRadius = UDim.new(0, 12)

    TweenService:Create(loadingBar, TweenInfo.new(2.8, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 1, 0)}):Play()

    wait(3)
    loadingGui:Destroy()
    createMainPanel()
end

