local function checkKey()
    local input = keyBox.Text:lower():gsub("%s+", "")
    if input == validKey then
        errorMsg.Text = "Key aceita! Carregando FX-Hub..."
        errorMsg.TextColor3 = Color3.fromRGB(0, 255, 100)
        errorMsg.Visible = true
        wait(1.2)
        keyGui:Destroy()
        showLoadingScreen()
    else
        errorMsg.Text = "Key inválida! Tente novamente."
        errorMsg.Visible = true
    end
end

enterBtn.MouseButton1Click:Connect(checkKey)
keyBox.FocusLost:Connect(function(enter) if enter then checkKey() end end)

